---
import '@fontsource-variable/inter';
import '@fontsource-variable/fira-code'; // Adding a monospace font for code elements
import '@fontsource-variable/montserrat';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Montserrat Variable';
    --aw-font-mono: 'Fira Code Variable', monospace; /* Developer-friendly monospace font */

    /* Developer theme color palette */
    --aw-color-primary: rgb(56, 189, 248); /* Bright blue, like syntax highlighting */
    --aw-color-secondary: rgb(49, 46, 129); /* Deep indigo for contrast */
    --aw-color-accent: rgb(232, 121, 249); /* Bright magenta for accents */
    --aw-color-success: rgb(16, 185, 129); /* Green for success/valid code */
    --aw-color-info: rgb(59, 130, 246); /* Blue for info */
    --aw-color-warning: rgb(245, 158, 11); /* Yellow for warnings */
    --aw-color-error: rgb(239, 68, 68); /* Red for errors */

    /* Text colors */
    --aw-color-text-heading: rgb(17, 24, 39);
    --aw-color-text-default: rgb(31, 41, 55);
    --aw-color-text-muted: rgb(75, 85, 99);
    --aw-color-bg-page: rgb(255, 255, 255);
    
    /* Code syntax colors */
    --aw-color-code-bg: rgb(243, 244, 246);
    --aw-color-code-text: rgb(31, 41, 55);
    --aw-color-code-border: rgb(229, 231, 235);

    /* Dark mode background */
    --aw-color-bg-page-dark: rgb(18, 24, 38);

    /* Pastel Colors */

    --pastel-blue-100: #d6f5f5;
    --pastel-blue-300: #a8e0e0;
    --pastel-blue-500: #7ac8d0;
    --pastel-blue-700: #5a9eaf;
    
    --pastel-pink-300: #ffd1dc;
    --pastel-pink-500: #ffb6c1;
    
    --pastel-orange-400: #ff9966;
    --pastel-orange-500: #ff7e4a;
    
    --pastel-teal-500: #4db6ac;
    --pastel-teal-600: #3a8c82;
    
    --pastel-yellow-400: #fff099;

    ::selection {
      background-color: var(--aw-color-primary);
      color: white;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Montserrat Variable';
    --aw-font-mono: 'Fira Code Variable', monospace;

    /* Dark mode colors */
    --aw-color-primary: rgb(56, 189, 248);
    --aw-color-secondary: rgb(99, 102, 241);
    --aw-color-accent: rgb(232, 121, 249);
    --aw-color-success: rgb(16, 185, 129);
    --aw-color-info: rgb(59, 130, 246);
    --aw-color-warning: rgb(245, 158, 11);
    --aw-color-error: rgb(239, 68, 68);

    /* Text colors in dark mode */
    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229, 236, 246);
    --aw-color-text-muted: rgb(148, 163, 184);
    
    /* Code syntax colors for dark mode */
    --aw-color-code-bg: rgb(30, 41, 59);
    --aw-color-code-text: rgb(226, 232, 240);
    --aw-color-code-border: rgb(51, 65, 85);

    --aw-color-bg-page: var(--aw-color-bg-page-dark);

    ::selection {
      background-color: var(--aw-color-primary);
      color: rgb(15, 23, 42);
    }
  }

  /* Terminal-style containers */
  .terminal-container {
    @apply font-mono bg-slate-900 text-white p-4 rounded-md shadow-md overflow-hidden border border-slate-700;
  }

  .terminal-header {
    @apply flex items-center mb-2 pb-2 border-b border-slate-700;
  }

  .terminal-dot {
    @apply w-3 h-3 rounded-full mx-1;
  }

  .terminal-red {
    @apply bg-red-500;
  }

  .terminal-yellow {
    @apply bg-yellow-500;
  }

  .terminal-green {
    @apply bg-green-500;
  }

  .terminal-body {
    @apply font-mono text-sm;
  }

  .terminal-prompt {
    @apply text-green-400 mr-2;
  }

  .terminal-command {
    @apply text-white;
  }

  .terminal-output {
    @apply text-gray-300 pl-4;
  }

  /* Code block styling */
  .code-block {
    @apply font-mono p-4 rounded-md text-sm overflow-auto;
    background-color: var(--aw-color-code-bg);
    color: var(--aw-color-code-text);
    border: 1px solid var(--aw-color-code-border);
  }

  /* Syntax highlighting classes */
  .code-keyword {
    @apply text-purple-500 dark:text-purple-400;
  }

  .code-function {
    @apply text-yellow-500 dark:text-yellow-300;
  }

  .code-string {
    @apply text-green-500 dark:text-green-300;
  }

  .code-comment {
    @apply text-gray-500 dark:text-gray-400;
  }

  .code-number {
    @apply text-blue-500 dark:text-blue-300;
  }

  .code-operator {
    @apply text-red-500 dark:text-red-300;
  }

  /* Code typing animation */
  .typing {
    border-right: 0.15em solid var(--aw-color-primary);
    white-space: nowrap;
    overflow: hidden;
    animation: typing 3.5s steps(30, end), blink-caret 0.75s step-end infinite;
  }

  @keyframes typing {
    from { width: 0 }
    to { width: 100% }
  }

  @keyframes blink-caret {
    from, to { border-color: transparent }
    50% { border-color: var(--aw-color-primary) }
  }

  /* Project card that looks like a code editor */
  .code-card {
    @apply rounded-xl overflow-hidden shadow-lg transition-all duration-300;
    background-color: var(--aw-color-code-bg);
    border: 1px solid var(--aw-color-code-border);
  }

  .code-card-header {
    @apply px-4 py-2 flex items-center justify-between;
    background-color: var(--aw-color-text-muted);
  }

  .code-card-title {
    @apply flex items-center;
  }

  .code-card-icon {
    @apply mr-2 h-4 w-4;
  }

  .code-card-tabs {
    @apply flex text-xs;
  }

  .code-card-tab {
    @apply px-3 py-1 border-b-2 font-medium;
  }

  .code-card-tab.active {
    border-color: var(--aw-color-primary);
  }

  .code-card-body {
    @apply p-5;
  }

  /* Base button styles */
  .btn {
    @apply inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background;
  }

  .btn-primary {
    @apply bg-primary text-white hover:bg-primary/90 h-10 px-4 py-2;
  }
  
  .btn-outline {
    @apply border border-input hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2;
  }

  .btn-ghost {
    @apply hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2;
  }

  /* Tag styling for technologies */
  .tech-tag {
    @apply inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2;
  }

  /* VSCode-inspired folder tree */
  .folder-tree {
    @apply font-mono text-sm;
  }

  .folder {
    @apply flex items-center cursor-pointer py-1 hover:bg-slate-100 dark:hover:bg-slate-800 px-2 rounded;
  }

  .folder-icon {
    @apply mr-2 text-yellow-500 dark:text-yellow-400;
  }

  .file {
    @apply flex items-center py-1 px-2 pl-6 hover:bg-slate-100 dark:hover:bg-slate-800 rounded;
  }

  .file-icon {
    @apply mr-2 text-blue-500 dark:text-blue-400;
  }

  /* For animated text cursors */
  .cursor::after {
    content: '|';
    animation: cursor 1.1s infinite step-start;
  }

  @keyframes cursor {
    50% { opacity: 0; }
  }

  /* GitHub-style contribution graph */
  .contribution-graph {
    @apply grid grid-cols-52 gap-1;
  }

  .contribution-cell {
    @apply w-3 h-3 rounded-sm;
  }

  .contribution-level-0 {
    @apply bg-gray-100 dark:bg-gray-800;
  }

  .contribution-level-1 {
    @apply bg-green-100 dark:bg-green-900;
  }

  .contribution-level-2 {
    @apply bg-green-300 dark:bg-green-700;
  }

  .contribution-level-3 {
    @apply bg-green-500 dark:bg-green-500;
  }

  .contribution-level-4 {
    @apply bg-green-700 dark:bg-green-300;
  }
</style>