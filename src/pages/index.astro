---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import DevHero from '~/components/widgets/DevHero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import AboutMe from '~/components/widgets/AboutMe.astro';
import ProjectSection from '~/components/widgets/ProjectSection.astro';
import SkillsComponent from '~/components/widgets/SkillsComponent.astro'

const metadata = {
  title: 'P. Vidakovic - Full-Stack Engineer',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'About', href: '#about' },
        { text: 'Projects', href: '#projects' },
        { text: 'Skills', href: '#skills' },
        { text: 'Blog', href: '#blog' },
        { text: 'Contact', href: '#contact' },
        { text: 'Github', href: 'https://github.com/yourusername' },
      ]}
      actions={[
        {
          text: 'Get in Touch',
          href: '#contact',
          class: 'btn-gradient',
        },
      ]}
      isSticky
      showToggleTheme
    >
    </Header>
  </Fragment>

  <!-- Hero Widget with Forest Inspired Background -->
  <!-- Hero Widget with Forest-Inspired Styling -->
  <DevHero
    id="hero-bg"
    image={{
      src: "~/assets/images/avataaars.png",
      alt: "sjdkb"
    }}
  >
  </DevHero>

  <!-- About Me Section with Forest-Inspired Styling -->
  <AboutMe id="about"  />

  <!-- Projects Section with Modern Card Layout -->
  <ProjectSection id="projects" />

  <!-- Skills Section -->
  <SkillsComponent id="skills"/>
  
  <!-- BlogLatestPost Widget **************** -->

  <BlogLatestPosts
    id="blog"
    title="From My Blog"
      >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="contact"
    title="Let's work together"
    subtitle="I'm currently available for freelance work or full-time opportunities. If you'd like to talk about a project or job opportunity, get in touch!"
    actions={[
      {
        variant: 'primary',
        text: 'Contact Me',
        href: 'mailto:your.email@example.com',
      },
    ]}
  />

</Layout>

<style is:global>
  /* Gradient button */
  .btn-gradient {
    background-image: linear-gradient(to right, var(--tw-gradient-stops));
    --tw-gradient-from: #2563eb;
    --tw-gradient-to: #4f46e5;
    --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to);
    color: white;
    transition: all 0.2s ease;
  }
  
  .btn-gradient:hover {
    --tw-gradient-from: #1d4ed8;
    --tw-gradient-to: #4338ca;
    --tw-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    box-shadow: var(--tw-shadow);
  }
  
  /* Blinking cursor animation */
  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }
  
  /* Animation for hero section background */
  #hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at bottom right, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
    animation: pulse 8s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: -1;
  }
  
  @keyframes pulse {
    0% { opacity: 0.5; }
    100% { opacity: 0.8; }
  }
</style>